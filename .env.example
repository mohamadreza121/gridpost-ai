# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GridPost AI

# Appwrite Cloud
# Example endpoint: https://cloud.appwrite.io/v1 or your region endpoint from Appwrite Console.
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=gridpost_ai
APPWRITE_STORAGE_BUCKET_ID=media
APPWRITE_COOKIE_NAME=

# Token encryption for social access/refresh tokens.
# Recommended: generate with `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
TOKEN_ENCRYPTION_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Inngest
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=GridPost AI <onboarding@resend.dev>
RESEND_NOTIFY_EMAIL=

# Future platform OAuth values. Add these one platform at a time.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/social/oauth/callback
